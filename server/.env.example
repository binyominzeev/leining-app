# Copy this file to .env and fill in values before running the server.

# Port the API server listens on (default: 3001)
PORT=3001

# Secret used to sign JWT tokens — CHANGE THIS to a long random string in production!
JWT_SECRET=change-me-to-a-long-random-secret

# Comma-separated list of origins the API should accept requests from
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Directory where the SQLite database file is stored (default: server/data/)
DATA_DIR=./data
